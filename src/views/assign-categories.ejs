<%- include('partials/header') %>

<main class="container">
    <h1><%= projectDetails.title %></h1>
    <h2>Assign Categories</h2>

    <form action="/assign-categories/<%= projectId %>" method="POST" class="form-card">
        
        <div class="form-group">
            <p>Select categories for this project:</p>
            
            <% categories.forEach(category => { %>
                <div class="checkbox-group">
                    <input
                        type="checkbox"
                        id="category-<%= category.category_id %>"
                        name="categoryIds" 
                        value="<%= category.category_id %>"
                        <%# Lógica para marcar los ya asignados %>
                        <%= assignedCategories.some(ac => ac.category_id === category.category_id) ? 'checked' : '' %>
                    />
                    <label for="category-<%= category.category_id %>">
                        <%= category.category_name %>
                    </label>
                </div>
            <% }); %>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Categories</button>
            <a href="/project/<%= projectId %>" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

<%- include('partials/footer') %>