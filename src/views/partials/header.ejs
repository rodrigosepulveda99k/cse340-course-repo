<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CSE 340 Service Network</title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>
    <header>
        <div class="nav-container"> <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/organizations">Organizations</a></li>
                    <li><a href="/projects">Projects</a></li>
                    <li><a href="/categories">Categories</a></li>

                    <% if (isLoggedIn) { %>
                        <% if (user && user.role_name === 'Admin') { %>
                            <li><a href="/new-project" class="admin-link">+ New Project</a></li>
                            <li><a href="/new-organization" class="admin-link">+ New Org</a></li>
                        <% } %>

                        <li><a href="/logout">Logout</a></li>
                        
                        <li class="user-display">
                            <span>Welcome, <strong><%= user.name %></strong></span>
                            <% if (user.role_name === 'Admin') { %>
                                <span class="badge">Admin</span>
                            <% } %>
                        </li>
                    <% } else { %>
                        <li><a href="/register">Register</a></li>
                        <li><a href="/login">Login</a></li>
                    <% } %>
                </ul>
            </nav>
        </div>

        <section class="messages">
            <% 
                const allMessages = typeof getMessages === 'function' ? getMessages() : (locals.messages || {}); 
                const types = Object.keys(allMessages);
            %>

            <% types.forEach(type => { %>
                <% if (Array.isArray(allMessages[type]) && allMessages[type].length > 0) { %>
                    <div class="alert <%= type %>"> <% allMessages[type].forEach(msg => { %>
                            <p><%= msg %></p>
                        <% }); %>
                    </div>
                <% } %>
            <% }); %>
        </section>
    </header>