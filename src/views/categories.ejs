<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    
    <section class="category-grid">
        <p class="intro-text">Browse our projects by category:</p>

        <% if (isLoggedIn && user && user.role_name === 'Admin') { %>
        <div class="actions-bar" style="margin-bottom: 20px;">
            <a href="/new-category" class="btn-primary">Add New Category</a>
        </div>
        <% } %>
        
        <ul class="category-list">
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach(category => { %>
                    <li class="category-card">    
                        <div class="category-info">
                            <strong>
                                <a href="/category/<%= category.category_id %>">
                                    <%= category.category_name %>
                                </a>
                            </strong>
                        </div>
                    </li>
                <% }); %>
            <% } else { %>
                <p>No categories available at the moment.</p>
            <% } %>
        </ul>
    </section>
</main>

<%- include('partials/footer') %>