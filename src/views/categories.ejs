<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <section class="category-grid">
        <p>Browse our projects by category:</p>
        <ul>
            <% categories.forEach(category => { %>
                <li>
                    <strong><%= category.category_name %></strong>
                </li>
            <% }); %>
        </ul>
    </section>
</main>

<%- include('partials/footer') %>