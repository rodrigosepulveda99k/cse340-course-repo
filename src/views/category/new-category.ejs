<% if (errors) { %>
  <ul>
    <% errors.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
<form action="/new-category" method="POST">
  <label for="category_name">Nombre de la Categoría:</label>
  <input type="text" 
         id="category_name" 
         name="category_name" 
         value="<%= category_name || '' %>"
         required 
         maxlength="100"> <button type="submit">Agregar Categoría</button>
</form>