<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p class="intro-text">Explore current service opportunities and join a project today.</p>

    <ul class="project-list">
        <% projects.forEach(project => { %>
            <li class="project-card">
                <div class="project-info">
                    <strong>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </strong>

                    <p><%= project.description %></p>

                    <p class="org-link">
                        Organized by: 
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </p>

                    <span class="status-tag">Upcoming</span>
                </div>
            </li>
        <% }); %>
    </ul>

    <p class="action-link">
    <a href="/new-project">Add a New Service Project</a>
    </p>
</main>

<%- include('partials/footer') %>